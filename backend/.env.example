PORT=3000
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
ADMIN_SECRET=your_admin_secret_for_manual_triggers

# Cron schedule for daily match creation (default: 9pm ET every night)
# Uses node-cron syntax with timezone: America/New_York
# See: https://crontab.guru
MATCH_CRON_SCHEDULE=0 21 * * *
